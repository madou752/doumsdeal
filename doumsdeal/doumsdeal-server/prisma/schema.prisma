generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ads {
  id            Int             @id @default(autoincrement())
  title         String          @db.VarChar(100)
  description   String
  price         Decimal         @default(0.00) @db.Decimal(10, 2)
  is_negotiable Boolean?        @default(false)
  condition     item_condition  @default(GOOD)
  image_url     String?         @db.VarChar(255)
  location      String?         @db.VarChar(100)
  views_count   Int?            @default(0)
  status        ad_status?      @default(AVAILABLE)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  user_id       Int
  category_id   Int
  categories    categories      @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  users         users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  favorites     favorites[]
  conversations conversations[]
}

model categories {
  id        Int     @id @default(autoincrement())
  name      String  @unique @db.VarChar(50)
  icon_name String? @db.VarChar(50)
  ads       ads[]
}

model users {
  id                      Int             @id @default(autoincrement())
  username                String          @unique @db.VarChar(50)
  email                   String          @unique @db.VarChar(255)
  password                String          @db.VarChar(255)
  avatar_url              String?         @db.VarChar(255)
  role                    user_role?      @default(USER)
  is_active               Boolean         @default(true)
  created_at              DateTime?       @default(now()) @db.Timestamp(6)
  updated_at              DateTime?       @default(now()) @db.Timestamp(6)
  ads                     ads[]
  favorites               favorites[]
  conversations_as_buyer  conversations[] @relation("ConvBuyer")
  conversations_as_seller conversations[] @relation("ConvSeller")
  messages_sent           messages[]
  logs                    logs[]
}

model logs {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  action      String    @db.VarChar(100)
  target_type String?   @db.VarChar(50)
  target_id   Int?
  details     String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model favorites {
  id         Int       @id @default(autoincrement())
  user_id    Int
  ad_id      Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ads        ads       @relation(fields: [ad_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, ad_id])
}

model conversations {
  id         Int        @id @default(autoincrement())
  buyer_id   Int
  seller_id  Int
  ad_id      Int
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  buyer      users      @relation("ConvBuyer", fields: [buyer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  seller     users      @relation("ConvSeller", fields: [seller_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ads        ads        @relation(fields: [ad_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages   messages[]

  @@unique([buyer_id, seller_id, ad_id])
}

model messages {
  id              Int           @id @default(autoincrement())
  conversation_id Int
  sender_id       Int
  content         String
  is_read         Boolean       @default(false)
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender          users         @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum ad_status {
  AVAILABLE
  SOLD
}

enum user_role {
  USER
  ADMIN
}

enum item_condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}
